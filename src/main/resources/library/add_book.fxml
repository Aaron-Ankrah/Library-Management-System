<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="library.controllers.AddBookController"
      styleClass="form-container">

    <!-- Header -->
    <VBox styleClass="form-header" spacing="4">
        <Label text="Add New Book" styleClass="form-title"/>
        <Label text="Fill in the details below to add a book to the library."
               styleClass="form-subtitle"/>
    </VBox>

    <!-- Body -->
    <VBox styleClass="form-body" spacing="16">

        <VBox spacing="5">
            <Label text="TITLE" styleClass="form-label"/>
            <TextField fx:id="titleField" promptText="e.g. Things Fall Apart" prefWidth="360"/>
        </VBox>

        <VBox spacing="5">
            <Label text="AUTHOR" styleClass="form-label"/>
            <TextField fx:id="authorField" promptText="e.g. Chinua Achebe" prefWidth="360"/>
        </VBox>

        <VBox spacing="5">
            <Label text="GENRE" styleClass="form-label"/>
            <TextField fx:id="genreField" promptText="e.g. Fiction, Science, History" prefWidth="360"/>
        </VBox>

        <VBox spacing="5">
            <Label text="QUANTITY" styleClass="form-label"/>
            <TextField fx:id="quantityField" promptText="e.g. 5" prefWidth="360"/>
        </VBox>

    </VBox>

    <!-- Footer -->
    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" styleClass="btn-secondary" onAction="#handleCancel"/>
        <Button text="Add Book" styleClass="btn-success" onAction="#handleAdd"/>
    </HBox>

</VBox>
